<% layout("/layouts/boilerplate") %>

<div class="row">
    <div class="col-8 offset-2">
        <br>
<div class="container mt-4">
  <h3 class="mb-4">Create a New Listing</h3>

  <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

    <!-- Title -->
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input 
        name="listing[title]" 
        type="text"
        class="form-control"
        required
      />
      <div class="valid-feedback">Title looks good</div>
      <div class="invalid-feedback">please enter a title</div>
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
      <textarea 
        name="listing[description]"
        class="form-control"
        rows="3"
      ></textarea>
    </div>

    <!-- Upload Image -->
    <div class="mb-3">
      <label for="image" class="form-label">Listing image</label>
      <input 
        name="listing[image]" 
        type="file" 
        class="form-control"
        required
      />
    </div>
    <!-- Category-->
    <div class="mb-3">
    <label for="category" class="form-label">Category</label>

    <select
        name="listing[category]"
        id="category"
        class="form-select"
        required
    >
        <option value="">Select a Category</option>

        <option value="Trending">Trending</option>
        <option value="Rooms">Rooms</option>
        <option value="Mountains">Mountains</option>
        <option value="Pools">Pools</option>
        <option value="Beach">Beach</option>
        <option value="Arctic">Arctic</option>
        <option value="Camping">Camping</option>
        <option value="Forest">Forest</option>
        <option value="Lakefront">Lakefront</option>
        <option value="Historical">Historical</option>
        <option value="City View">City View</option>
        <option value="Cabins">Cabins</option>
        <option value="Luxury">Luxury</option>
        <option value="Farm Stay">Farm Stay</option>
        <option value="Boats">Boats</option>
    </select>

    <div class="invalid-feedback">
        Please select a category.
    </div>
</div>

    <!-- Price -->
    <div class="row">
    <div class="mb-3 col-4">
      <label for="price" class="form-label">Price</label>
      <input 
        name="listing[price]" 
        type="number" 
        class="form-control"
        placeholder="Enter price"
        required
      />
      <div class="invalid-feedback">please enter a price</div>
    </div>

    <!-- Country -->
    <div class="mb-3 col-md-8">
      <label for="country" class="form-label">Country</label>
      <input 
        name="listing[country]" 
        type="text" 
        class="form-control"
        placeholder="Enter country"
        required
      />
    </div>
    <div class="invalid-feedback">please enter the country name</div>
    </div>

    <!-- Location -->
    <div class="mb-3">
      <label for="location" class="form-label">Location</label>
      <input 
        name="listing[location]" 
        type="text" 
        class="form-control"
        placeholder="Enter location"
        required
      />
      <div class="invalid-feedback">please enter a location</div>
    </div>
    <!-- Button -->
    <button class="btn btn-dark add-btn" >Add Listing</button>

  </form>
</div>
</div>
</div>
<br>
